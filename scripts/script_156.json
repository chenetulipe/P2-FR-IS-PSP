    "data_size": 124,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "[1432][NULL][NULL][0014]Welcome,[SP]one[SP]and[SP]all,[SP]to[SP]my[SP]shrine![1432][NULL][NULL][0014]",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "[1432][NULL][NULL][0014]Bienvenue à tous dans mon sanctuaire![1432][NULL][NULL][0014]"
  },
  {
    "id": 1,
    "offset": 346966,
    "slot_size": 292,
    "data_size": 288,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "You[SP]look[SP]like[SP]you've[SP]got[SP]a[SP]real[SP]weight[SP]off\nyour[SP]chest[SP]now[SP]that[SP]you've[SP]spilled[SP]the[SP]beans\nabout[SP]not[SP]speaking[SP]a[SP]word[SP]of[SP]English!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Tu as l'air d'avoir un vrai poids\nen moins depuis que tu as avoué\nne pas parler un mot d'anglais!"
  },
  {
    "id": 2,
    "offset": 347258,
    "slot_size": 82,
    "data_size": 78,
    "nom_orig": "Ginko",
    "texte_orig": "Yeah,[SP]no[SP]thanks[SP]to[SP]you...[1205][001E]",
    "nom_fr": "Ginko",
    "texte_fr": "Ouais, pas merci à toi...[1205][001E]"
  },
  {
    "id": 3,
    "offset": 347340,
    "slot_size": 268,
    "data_size": 264,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "But[SP]what[SP]about[SP]all[SP]the[SP]OTHER[SP]stuff[SP]you[SP]haven't\nmentioned[SP]yet,[SP]huh?[SP]Like[SP]swindling[SP]money[SP]from\nperverted[SP]old[SP]farts?",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Et le RESTE que tu as tu,\nhein? Comme racketter\nles vieux pervers?"
  },
  {
    "id": 4,
    "offset": 347608,
    "slot_size": 290,
    "data_size": 286,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "And[SP]experimenting[SP]with[SP]those[SP]nassssty[SP]drugs?\nIt's[SP]a[SP]little[SP]late[SP]to[SP]regret[SP]it[SP]all,[SP]even[SP]if\nyou[SP]were[SP]rebelling[SP]against[SP]Steven!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Et expérimenter ces vilaiiines\ndrogues? C'est un peu tard pour\nregretter, même si tu te rebellais\ncontre Steven!"
  },
  {
    "id": 5,
    "offset": 347898,
    "slot_size": 312,
    "data_size": 308,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "Poor[SP]Mami[SP]and[SP]Miho[SP]got[SP]dragged[SP]into[SP]your\nmess,[SP]too.[SP][1432][NULL][NULL][0014]They[SP]all[SP]just[SP]wanna[SP]get[SP]close[SP]and\nbask[SP]in[SP]my[SP]glory![1432][NULL][NULL][0014][SP]Talk[SP]about[SP]an[SP]ego[SP]trip!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Mami et Miho ont été\npiégées avec toi.\n[1432][NULL][NULL][0014]Tous veulent m'approcher\npour briller sous ma gloire![1432][NULL][NULL][0014]\nQuel ego trip!"
  },
  {
    "id": 6,
    "offset": 348210,
    "slot_size": 278,
    "data_size": 274,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "I[SP]mean,[SP]you[SP]were[SP]only[SP]dogging[SP][U+1113][SP]'cause\nyou[SP]were[SP]after[SP]the[SP]same[SP]status[SP]that[SP]you[SP]hated\neveryone[SP]else[SP]exploiting[SP]you[SP]for!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Tu suivais [U+1113] juste pour\nchercher ce même statut que tu\ndétestais voir les autres\nexploiter chez toi!"
  },
  {
    "id": 7,
    "offset": 348488,
    "slot_size": 40,
    "data_size": 36,
    "nom_orig": "Ginko",
    "texte_orig": "......",
    "nom_fr": "Ginko",
    "texte_fr": "......"
  },
  {
    "id": 8,
    "offset": 348528,
    "slot_size": 306,
    "data_size": 302,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "You[SP]say[SP]you[SP]hate[SP]being[SP]different,[SP]but[SP]really,\nyou[SP]want[SP]to[SP]be[SP]noticed.[SP]That's[SP]why[SP]you[SP]went[SP]for\n[U+1113],[SP]the[SP]center[SP]of[SP]everyone's[SP]attention!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Tu dis détester être différente,\nmais tu veux qu'on te remarque.\nC'est pour ça que tu visais [U+1113],\nle centre de l'attention!"
  },
  {
    "id": 9,
    "offset": 348834,
    "slot_size": 292,
    "data_size": 288,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "You're[SP]desperate[SP]for[SP]someone[SP]to[SP]lean[SP]against,\nbut[SP]you[SP]don't[SP]believe[SP]in[SP]anyone![SP]Honestly,\nwhat[SP]a[SP]selfish[SP]little[SP]bitch[SP]you[SP]are!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Tu as tellement besoin de t'appuyer\nsur quelqu'un, mais tu ne crois\nen personne! Franchement,\nquelle peste égoïste!"
  },
  {
    "id": 10,
    "offset": 349126,
    "slot_size": 180,
    "data_size": 176,
    "nom_orig": "Ginko",
    "texte_orig": "You're[SP]absolutely[SP]right...[1205][001E][SP]I[SP]was[SP]a[SP]pathetic\nlittle[SP]girl[SP]for[SP]a[SP]long[SP]time...",
    "nom_fr": "Ginko",
    "texte_fr": "C'est très vrai...[1205][001E]\nJ'ai été une gamine pathétique\nlongtemps..."
  },
  {
    "id": 11,
    "offset": 349306,
    "slot_size": 118,
    "data_size": 114,
    "nom_orig": "Ginko",
    "texte_orig": "But[SP]I'm[SP]different[SP]now.[SP]I[SP]found[SP]what[SP]I[SP]lost...",
    "nom_fr": "Ginko",
    "texte_fr": "J'ai changé. J'ai\nretrouvé ce qui manquait..."
  },
  {
    "id": 12,
    "offset": 349424,
    "slot_size": 212,
    "data_size": 208,
    "nom_orig": "Ginko",
    "texte_orig": "You[SP]should[SP]remember,[SP]if[SP]you're[SP]me.[SP]My[SP]dream\nten[SP]years[SP]ago[SP]was[SP]to[SP]marry[SP]my[SP]first[SP]love...\n[U+1113]...",
    "nom_fr": "Ginko",
    "texte_fr": "Souviens-t'en, si tu es moi.\nMon rêve il y a 10 ans était\nd'épouser mon 1er amour...\n[U+1113]..."
  },
  {
    "id": 13,
    "offset": 349636,
    "slot_size": 172,
    "data_size": 168,
    "nom_orig": "Shadow[SP]Ginko",
    "texte_orig": "Stop...![1205][001E][SP]The[SP][U+1113][SP]I[SP]loved[SP]died[SP]back[SP]then!\nSo[SP]he'll[SP]always[SP]be[SP]mine!",
    "nom_fr": "Ombre de Ginko",
    "texte_fr": "Stop![1205][001E] Le [U+1113] que j'aimais\nest mort! Il\nrestera mien!"
  },
  {
    "id": 14,
    "offset": 349808,
    "slot_size": 222,
    "data_size": 218,
    "nom_orig": "Ginko",
    "texte_orig": "I[SP]won't[SP]let[SP]anyone[SP]tell[SP]me[SP]how[SP]I[SP]feel.\n[U+1113]'s[SP]feelings[SP]are[SP]his[SP]business.\nBut[SP]my[SP]feelings[SP]are[SP]mine...",
    "nom_fr": "Ginko",
    "texte_fr": "Personne ne dictera mon coeur.\nCe que [U+1113] ressent le regarde.\nMais mes sentiments sont à moi..."
  },
  {
    "id": 15,
    "offset": 350030,
    "slot_size": 98,
    "data_size": 94,
    "nom_orig": "Ginko",
    "texte_orig": "And[SP]even[SP]if[SP][U+1113][SP]hates[SP]me,[SP]I[SP]love[SP]him.",
    "nom_fr": "Ginko",
    "texte_fr": "Et même si [U+1113] me déteste,\nje l'aime."
  }
]
