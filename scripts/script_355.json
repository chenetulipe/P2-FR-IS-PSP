  {
    "id": 16,
    "offset": 363598,
    "slot_size": 156,
    "data_size": 152,
    "nom_orig": "Maya",
    "texte_orig": "The[SP]Oracle[SP]of[SP]Maia...[SP]End[SP]of[SP]Nahui-Ollin...\nWhat[SP]does[SP]it[SP]all[SP]mean?",
