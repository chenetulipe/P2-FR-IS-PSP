  {
    "id": 13,
    "offset": 362886,
    "slot_size": 242,
    "data_size": 238,
    "nom_orig": "Maya",
    "texte_orig": "My[SP]friend[SP]goes[SP]here,[SP]and[SP]every[SP]time[SP]he[SP]comes\nback,[SP]he[SP]asks[SP]if[SP]he[SP]looks[SP]any[SP]different.[SP]But[SP]I\ncan[SP]never[SP]tell...",
