  {
    "id": 8,
    "offset": 361904,
    "slot_size": 162,
    "data_size": 158,
    "nom_orig": "Eikichi",
    "texte_orig": "Jun...[SP]does[SP]your[SP]paradise[SP]always[SP]have[SP]to\ninvolve[SP]these[SP]sacrifices?",
