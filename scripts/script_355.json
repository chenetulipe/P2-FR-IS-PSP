  {
    "id": 19,
    "offset": 364342,
    "slot_size": 264,
    "data_size": 260,
    "nom_orig": "Maya",
    "texte_orig": "Joker[SP]told[SP]them[SP]to[SP]protect[SP]the[SP]people[SP]of[SP]the\ncity[SP]because[SP]Jun[SP]still[SP]has[SP]a[SP]conscience.\nHe[SP]hasn't[SP]lost[SP]himself[SP]completely.",
