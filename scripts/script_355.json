  {
    "id": 20,
    "offset": 364606,
    "slot_size": 144,
    "data_size": 140,
    "nom_orig": "Maya",
    "texte_orig": "If[SP]we[SP]find[SP]him,[SP]I'm[SP]sure[SP]he'll[SP]return[SP]to[SP]his\nold,[SP]kind[SP]self.",
