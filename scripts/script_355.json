  {
    "id": 7,
    "offset": 361614,
    "slot_size": 290,
    "data_size": 286,
    "nom_orig": "Eikichi",
    "texte_orig": "Some[SP]people[SP]got[SP]their[SP]ideals[SP]granted[SP]and[SP]some\nbecame[SP]shadowmen.[SP]Some[SP]people[SP]get[SP]to[SP]turn\ninto[SP]Idealians[SP]and[SP]some[SP]will[SP]die[SP]on[SP]Earth.",
