  {
    "id": 4,
    "offset": 358268,
    "slot_size": 50,
    "data_size": 46,
    "nom_orig": "Eikichi",
    "texte_orig": "A[SP]service?",
    "nom_fr": "Eikichi",
    "texte_fr": "Quoi ?"
  },
  {
    "id": 5,
    "offset": 358318,
    "slot_size": 246,
    "data_size": 242,
    "nom_orig": "Yasuo",
    "texte_orig": "Prior[SP]to[SP]this,[SP]Kasugayama[SP]High[SP]was[SP]best[SP]known\nfor[SP]its[SP]poor[SP]academic[SP]standing[SP]and[SP]lack[SP]of\ndiscipline.[SP]But[SP]now?",
    "nom_fr": "Yasuo",
    "texte_fr": "Kasugayama était connu pour son manque\nde rigueur et ses piètres résultats.\nMais maintenant ?"
  },
  {
    "id": 6,
    "offset": 358564,
    "slot_size": 290,
    "data_size": 286,
    "nom_orig": "Yasuo",
    "texte_orig": "Our[SP]school's[SP]reputation[SP]has[SP]skyrocketed!\nStudents[SP]who[SP]were[SP]called[SP]scum[SP]are[SP]now[SP]highly\nsought[SP]after[SP]by[SP]the[SP]girls[SP]from[SP]other[SP]schools!",
    "nom_fr": "Yasuo",
    "texte_fr": "La réputation du lycée a explosé ! \nNous qui étions considérés comme des déchets,\nsommes les préférés des filles !"
  },
  {
    "id": 7,
    "offset": 358854,
    "slot_size": 242,
    "data_size": 238,
    "nom_orig": "Yasuo",
    "texte_orig": "It's[SP]all[SP]thanks[SP]to[SP]me,[SP]your[SP]student[SP]council\npresident,[SP]that[SP]this[SP]school[SP]has[SP]seen[SP]such[SP]a\nradical[SP]turnaround!",
    "nom_fr": "Yasuo",
    "texte_fr": "Et ce changement est de mon fait,\nc'était mon devoir de président du BDE !"
  },
  {
    "id": 8,
    "offset": 359096,
    "slot_size": 182,
    "data_size": 178,
    "nom_orig": "Yasuo",
    "texte_orig": "Well[SP]done[SP]in[SP]spotting[SP]me...[SP]No[SP]wonder[SP]you\nescaped[SP]from[SP]that[SP]air[SP]raid[SP]shelter.",
    "nom_fr": "Yasuo",
    "texte_fr": "Quelle perspicacité... Il est normal\nque vous vous soyez échappés sans peine."
  },
  {
    "id": 9,
    "offset": 359278,
    "slot_size": 84,
    "data_size": 80,
    "nom_orig": "Ginko",
    "texte_orig": "How[SP]frickin'[SP]stupid[SP]are[SP]you?",
    "nom_fr": "Ginko",
    "texte_fr": "Quelle indignité..."
  },
  {
    "id": 10,
    "offset": 359362,
    "slot_size": 154,
    "data_size": 150,
    "nom_orig": "Yasuo",
    "texte_orig": "D-Don't[SP]call[SP]me[SP]stupid![SP]Your[SP]ilk[SP]can[SP]never\nunderstand[SP]my[SP]value!",
    "nom_fr": "Yasuo",
    "texte_fr": "Indigne ? MOI ? Vous ne comprenez\nrien !"
  },
  {
    "id": 11,
    "offset": 359516,
    "slot_size": 278,
    "data_size": 274,
    "nom_orig": "Yasuo",
    "texte_orig": "Hmph...[1205][001E][SP]Say[SP]what[SP]you[SP]will,[SP]but[SP]if[SP]this[SP]school\nfestival[SP]succeeds,[SP]there's[SP]no[SP]doubt[SP]that[SP]my\nreputation[SP]will[SP]soar[SP]even[SP]higher.",
    "nom_fr": "Yasuo",
    "texte_fr": ""
  },
  {
    "id": 12,
    "offset": 359794,
    "slot_size": 148,
    "data_size": 144,
    "nom_orig": "Yasuo",
    "texte_orig": "Now[SP]then,[SP]I[SP]have[SP]a[SP]bit[SP]of[SP]a[SP]proposition\nfor[SP]you,[SP]Mishina-kun.",
    "nom_fr": "Yasuo",
    "texte_fr": "Maintenant mon cher Mishina, j'ai\nune proposition pour toi."
  },
  {
    "id": 13,
    "offset": 359942,
    "slot_size": 256,
    "data_size": 252,
    "nom_orig": "Yasuo",
    "texte_orig": "I[SP]plan[SP]to[SP]proceed[SP]with[SP]my[SP]agenda[SP]of[SP]reshaping\nthis[SP]school[SP]and,[SP]in[SP]the[SP]near[SP]future,[SP]gaining\ncomplete[SP]control[SP]of[SP]it.",
    "nom_fr": "Yasuo",
    "texte_fr": "Je projette de prendre le contrôle total\nde ce lycée et de le réformer comme\nil se doit !"
  },
  {
    "id": 14,
    "offset": 360198,
    "slot_size": 152,
    "data_size": 148,
    "nom_orig": "Yasuo",
    "texte_orig": "I'd[SP]like[SP]for[SP]you[SP]to[SP]wrest[SP]control[SP]of[SP]the\ninside[SP]of[SP]the[SP]school.",
    "nom_fr": "Yasuo",
    "texte_fr": "J'aimerais que tu prennes le contrôle à\nl'interieur."
  },
  {
    "id": 15,
    "offset": 360350,
    "slot_size": 284,
    "data_size": 280,
    "nom_orig": "Yasuo",
    "texte_orig": "If[SP]we[SP]joined[SP]forces,[SP]assuming[SP]full[SP]control[SP]of\nKasugayama[SP]High[SP]from[SP]the[SP]inside[SP]and[SP]out,[SP]this\nwould[SP]become[SP]a[SP]top-tier[SP]institution!",
    "nom_fr": "Yasuo",
    "texte_fr": "En unissant nos forces, on pourrait\ncontrôler le lycée entièrement ! Et\nen faire un établissement hors-pair !"
  },
  {
    "id": 16,
    "offset": 360634,
    "slot_size": 110,
    "data_size": 106,
    "nom_orig": "Yasuo",
    "texte_orig": "Well?[SP]A[SP]perfect[SP]plan,[SP]wouldn't[SP]you[SP]agree?",
    "nom_fr": "Yasuo",
    "texte_fr": "Un plan parfait n'est-ce pas ?"
  },
  {
    "id": 17,
    "offset": 360744,
    "slot_size": 148,
    "data_size": 144,
    "nom_orig": "Eikichi",
    "texte_orig": "Screw[SP]that[SP]noise![SP]Who[SP]would[SP]want[SP]in[SP]on[SP]a\nplan[SP]that[SP]shady!?",
