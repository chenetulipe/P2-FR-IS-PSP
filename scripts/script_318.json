    "data_size": 192,
    "nom_orig": "Mr.[SP]Tomi",
    "texte_orig": "Welcome[SP]to[SP]Tominaga[SP]Chiropractic![1205][001E]\nI[SP]am[SP]Mr.[SP]Tomi,[SP]the[SP]man[SP]with[SP]the[SP]magic[SP]fingers.",
