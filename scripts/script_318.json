  {
    "id": 4,
    "offset": 254708,
    "slot_size": 210,
    "data_size": 206,
    "nom_orig": "Jun",
    "texte_orig": "Nobody[SP]wants[SP]problems,[SP]or[SP]suffering...[SP]or[SP]sorrow.[1205][U+000F]\nI[SP]thought[SP]I'd[SP]get[SP]rid[SP]of[SP]all[SP]those[SP]things.",
