    "offset": 363718,
    "slot_size": 296,
    "data_size": 292,
    "nom_orig": "Concerned[SP]mother",
    "texte_orig": "This[SP]Masked[SP]Circle[SP]must[SP]be[SP]the[SP]terrorists\nbehind[SP]these[SP]attacks.[SP]I[SP]knew[SP]as[SP]soon[SP]as[SP]I[SP]heard\nthe[SP]name[SP]that[SP]they'd[SP]be[SP]dangerous.",
