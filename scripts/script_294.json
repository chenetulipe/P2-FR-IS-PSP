  {
    "id": 61,
    "offset": 364014,
    "slot_size": 308,
    "data_size": 304,
    "nom_orig": "Concerned[SP]mother",
    "texte_orig": "The[SP]In[SP]Lak'ech?[SP]Yes,[SP]I[SP]read[SP]it.[SP]I'm[SP]sure[SP]the\nMasked[SP]Circle[SP]read[SP]it,[SP]too,[SP]and[SP]engineered\nthese[SP]tragedies[SP]according[SP]to[SP]its[SP]prophecy.",
    "nom_fr": "Mère inquiète",
