  {
    "id": 6,
    "offset": 345236,
    "slot_size": 128,
    "data_size": 124,
    "nom_orig": "Fujii",
    "texte_orig": "Did[SP]you...[1205][001E][SP]get[SP]my[SP]camera?[SP]From[SP]the\nhead[SP]monk...?",
