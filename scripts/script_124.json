    "data_size": 102,
    "nom_orig": "Yukino",
    "texte_orig": "Yeah...[1205][001E][SP]See?[SP]I[SP]have[SP]it[SP]right[SP]here...",
    "nom_fr": "Yukino",
    "texte_fr": "Oui...[1205][001E] Tu vois? Je l'ai juste ici..."
