  {
    "id": 9,
    "offset": 265752,
    "slot_size": 156,
    "data_size": 152,
    "nom_orig": "Tamaki",
    "texte_orig": "Can[SP]you[SP]give[SP]us[SP]any[SP]more[SP]details?\nWe're[SP]investigating[SP]Joker[SP]too.",
