  {
    "id": 12,
    "offset": 266618,
    "slot_size": 178,
    "data_size": 174,
    "nom_orig": "Lisa",
    "texte_orig": "Yeah![SP]If[SP]rumors[SP]are[SP]coming[SP]true,[SP]we[SP]can[SP]spread\nrumors[SP]that[SP]work[SP]in[SP]our[SP]favor!",
    "nom_fr": "Lisa",
    "texte_fr": "Ouais ! Si les rumeurs se réalisent, on peut\nen profiter !"
