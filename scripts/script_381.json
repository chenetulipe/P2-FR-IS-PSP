    "data_size": 162,
    "nom_orig": "Lisa",
    "texte_orig": "Aiyah![SP]Then[SP]the[SP]rumors[SP]about[SP]the[SP]secret[SP]dish\nand[SP]the[SP]weapons[SP]dealing...",
