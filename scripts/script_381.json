  {
    "id": 17,
    "offset": 267558,
    "slot_size": 182,
    "data_size": 178,
    "nom_orig": "Tamaki",
    "texte_orig": "Talk[SP]to[SP]the[SP]Chief[SP]to[SP]request[SP]a[SP]rumor[SP]job.\nHe[SP]likes[SP]the[SP]paperwork[SP]filled[SP]in...",
