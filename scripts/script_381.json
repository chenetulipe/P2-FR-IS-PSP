    "data_size": 154,
    "nom_orig": "Lisa",
    "texte_orig": "Oh,[SP]no,[SP]we[SP]just[SP]had[SP]a[SP]question...[1205][001E][SP]Can[SP]we[SP]see\nthe[SP]chief[SP]detective?",
