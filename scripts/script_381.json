  {
    "id": 11,
    "offset": 266432,
    "slot_size": 186,
    "data_size": 182,
    "nom_orig": "Chief[SP]Todoroki",
    "texte_orig": "Well?[SP]Do[SP]you[SP]want[SP]us[SP]to[SP]spread[SP]the[SP]rumor[SP]about\nwhat[SP]the[SP]secret[SP]dish[SP]is?",
    "nom_fr": "Chef Todoroki",
