  {
    "id": 15,
    "offset": 267194,
    "slot_size": 174,
    "data_size": 170,
    "nom_orig": "Lisa",
    "texte_orig": "Let's[SP]have[SP]them[SP]spread[SP]the[SP]rumor.[SP]We[SP]have[SP]to\ntake[SP]any[SP]advantage[SP]we[SP]can[SP]get.",
    "nom_fr": "Lisa",
    "texte_fr": "Faisons propager la rumeur par eux. On\ndoit profiter de chaque avantage."
  },
  {
    "id": 16,
    "offset": 267368,
    "slot_size": 190,
    "data_size": 186,
    "nom_orig": "Lisa",
    "texte_orig": "Off[SP]to[SP]Shiraishi[SP]Ramen![SP]Let's[SP]go[SP]see[SP]if[SP]the\nrumor[SP]came[SP]true![SP]I'm[SP]sure[SP]it[SP]must[SP]have!",
