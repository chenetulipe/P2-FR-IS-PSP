  {
    "id": 15,
    "offset": 336950,
    "slot_size": 174,
    "data_size": 170,
    "nom_orig": "Concert[SP]staff",
    "texte_orig": "I[SP]asked[SP]my[SP]friends,[SP]but[SP]they[SP]were[SP]all[SP]too\nbusy[SP]to[SP]cover[SP]for[SP]me...",
    "nom_fr": "Employé du concert",
    "texte_fr": "Je devais demander à des amis, mais ils étaient tous trop\noccupés pour couvrir mes arrières..."
