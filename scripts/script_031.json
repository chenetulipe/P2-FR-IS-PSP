  {
    "id": 14,
    "offset": 336744,
    "slot_size": 206,
    "data_size": 202,
    "nom_orig": "Concert[SP]staff",
    "texte_orig": "I[SP]was[SP]supposed[SP]to[SP]go[SP]to[SP]Olivia-chan's[SP]show\ntoday,[SP]but[SP]I[SP]suddenly[SP]got[SP]called[SP]up...",
