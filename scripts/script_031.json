    "offset": 338852,
    "slot_size": 238,
    "data_size": 234,
    "nom_orig": "Concert[SP]staff",
    "texte_orig": "Oh,[SP]you[SP]don't[SP]have[SP]the[SP]money[SP]yet?[SP]Then[SP]I\ncan't[SP]sell[SP]these[SP]to[SP]you.[SP]Come[SP]back[SP]when\nyou[SP]have[SP]enough.",
    "nom_fr": "Employé de concert",
