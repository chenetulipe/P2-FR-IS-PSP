  {
    "id": 16,
    "offset": 337124,
    "slot_size": 238,
    "data_size": 234,
    "nom_orig": "Concert[SP]staff",
    "texte_orig": "Hey,[SP]only[SP]staffers[SP]are[SP]allowed[SP]through[SP]here.\nI[SP]know[SP]it's[SP]annoying,[SP]but[SP]we[SP]have[SP]to[SP]do[SP]our\njob[SP]too.",
