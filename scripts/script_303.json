  {
    "id": 10,
    "offset": 271266,
    "slot_size": 174,
    "data_size": 170,
    "nom_orig": "Male[SP]student",
    "texte_orig": "Y-You're[SP]right.[SP]I[SP]can't[SP]keep[SP]letting[SP]the[SP]Boss\ndo[SP]everything[SP]for[SP]me.",
