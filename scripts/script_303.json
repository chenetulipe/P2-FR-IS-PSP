    "data_size": 200,
    "nom_orig": "Male[SP]student",
    "texte_orig": "I-I[SP]mean,[SP]I[SP]don't[SP]have[SP]much[SP]confidence...\nBut[SP]I'll[SP]at[SP]least[SP]try[SP]to[SP]protect[SP]myself!",
