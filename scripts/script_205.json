  {
    "id": 2,
    "offset": 186332,
    "slot_size": 276,
    "data_size": 272,
    "nom_orig": "False[SP]Kashihara",
    "texte_orig": "Allow[SP]me[SP]to[SP]welcome[SP]you[SP]once[SP]more[SP]and\ncongratulate[SP]you[SP]on[SP]arriving[SP]at[SP]the[SP]world\nof[SP]the[SP]collective[SP]unconsciousness.",
