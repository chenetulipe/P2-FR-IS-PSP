  },
  {
    "id": 14,
    "offset": 254628,
    "slot_size": 242,
    "data_size": 238,
    "nom_orig": "Jun's[SP]father",
    "texte_orig": "And[SP]that's[SP]why[SP]I[SP]gave[SP]you[SP]that[SP]power[SP]and[SP]the\nIn[SP]Lak'ech.[SP]Your[SP]dream[SP]has[SP]come[SP]true,[SP]so[SP]why\nresist[SP]me?",
    "nom_fr": "Père de Jun",
    "texte_fr": "Et je t'ai donné ce pouvoir et l'In Lak'ech\npour que ton rêve se réalise, alors pourquoi\nme résister?"
  },
  {
    "id": 15,
    "offset": 254870,
    "slot_size": 286,
    "data_size": 282,
    "nom_orig": "Jun's[SP]father",
    "texte_orig": "It's[SP]your[SP]turn[SP]now[SP]to[SP]grant[SP]MY[SP]dream...[1205][001E]\nAnd[SP]as[SP]your[SP]father,[SP]I[SP]will[SP]eliminate[SP]anyone\nwho[SP]tries[SP]to[SP]deceive[SP]you.[SP]Now,[SP]come.",
    "nom_fr": "Père de Jun",
    "texte_fr": "C'est désormais à toi de réaliser MON rêve...[1205][001E]\nEn tant que père, j'écraserais tout\nceux qui te manipulent. Alors viens."
  },
  {
    "id": 16,
    "offset": 255156,
    "slot_size": 148,
    "data_size": 144,
    "nom_orig": "Jun",
    "texte_orig": "I[SP]won't[SP]let[SP]anyone[SP]hurt[SP]Big[SP]Maya...[1205][001E]\nNot[SP]even[SP]you,[SP]Father...!",
