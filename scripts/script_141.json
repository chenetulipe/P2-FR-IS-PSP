  },
  {
    "id": 13,
    "offset": 254388,
    "slot_size": 240,
    "data_size": 236,
    "nom_orig": "Jun",
    "texte_orig": "Father...[SP]We[SP]need[SP]to[SP]stop[SP]this...[1205][001E][SP]I...[SP]I[SP]just\nwanted[SP]to[SP]be[SP]like[SP]Big[SP]Sis[SP]and[SP]lead[SP]everyone\nto[SP]their[SP]dreams!",
